# ── API keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=                          # only if using anthropic/ prefixed models

# ── Models ───────────────────────────────────────────────────────────
# LiteLLM routes by model string — prefix with "anthropic/" for Claude
STAGE1_MODEL=gpt-4o-mini
STAGE2_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# ── GitHub ───────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=                      # generate with: openssl rand -hex 16

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                             # required for Qdrant Cloud
QDRANT_COLLECTION=arch_decisions

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Slack ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Detection tuning ────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.7
STAGE1_THRESHOLD=0.5
ALERT_CHANNEL=slack

# ── Service mapping ─────────────────────────────────────────────────
# JSON map of file path prefixes to service names
SERVICE_MAP={"services/auth":"auth-service","services/payments":"payments-service"}

# ── Server ──────────────────────────────────────────────────────────
WEBHOOK_PORT=3456

# ── Confluence (optional) ───────────────────────────────────────────
CONFLUENCE_BASE_URL=
CONFLUENCE_TOKEN=
CONFLUENCE_SPACE_KEY=

# ── Jira (optional) ────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_TOKEN=